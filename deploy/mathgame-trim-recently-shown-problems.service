[Unit]
Description=Mathgame trim_recently_shown_problems job
After=network-online.target
Wants=network-online.target systemd-networkd-wait-online.service

[Service]
Type=oneshot
WorkingDirectory=/home/ubuntu/mathgame_2
ExecStart=/usr/bin/flock -n /var/lock/mathgame-trim-recently-shown-problems.lock /home/ubuntu/mathgame_2/bin/trim_recently_shown_problems -config /home/ubuntu/mathgame_2/conf.json

[Install]
WantedBy=multi-user.target
